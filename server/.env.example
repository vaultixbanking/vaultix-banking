# ─── Vaultix Server Environment Variables ─────────────────────────────────────
#
# Copy this file to .env and fill in YOUR values.
#

# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vaultix"

# Direct database URL for Prisma migrations (bypasses connection pooler)
# Required for Supabase/PgBouncer — use port 5432 (direct) instead of 6543 (pooler)
# DIRECT_URL="postgresql://postgres.xxx:PASSWORD@db.xxx.supabase.co:5432/postgres"

# JWT secret – use a long random string in production
JWT_SECRET="change-me-to-a-real-secret"

# Admin credentials 
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Server
PORT=5000
NODE_ENV="development"

# CORS – frontend origin
CORS_ORIGIN="http://localhost:3000"
