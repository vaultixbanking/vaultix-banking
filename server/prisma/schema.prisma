// ─── Prisma Schema ─ Vaultix Banking API ────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── User ───────────────────────────────────────────────────────────────────

model User {
  id             String   @id @default(cuid())

  // ─── Personal Information (Step 1) ──────────────────────────────────────────
  fullName           String
  dateOfBirth        String?
  gender             String?
  nationality        String?
  country            String?
  city               String?
  state              String?
  zipCode            String?
  residentialAddress String?
  phone              String
  alternatePhone     String?

  // ─── Employment & Financial (Step 2) ────────────────────────────────────────
  employmentStatus   String?
  occupation         String?
  incomeRange        String?
  sourceOfFunds      String?

  // ─── Account & Security (Step 3) ────────────────────────────────────────────
  username       String   @unique
  emailAddress   String   @unique
  password       String
  pin            String
  accountNumber  String   @unique
  accountType    String   @default("Savings")
  currencyType   String   @default("USD")

  // ─── Email Verification ────────────────────────────────────────────────────
  emailVerified           Boolean   @default(false)
  emailVerificationToken  String?   @unique
  emailVerificationExpiry DateTime?

  // ─── ID Verification ───────────────────────────────────────────────────────
  idType         String?
  idNumber       String?
  idExpiryDate   String?
  photoID        String?

  // ─── Dashboard stats ───────────────────────────────────────────────────────
  totalBalance   Float    @default(0)
  loan           Float    @default(0)
  expenses       Float    @default(0)
  paymentToday   Float    @default(0)
  newLoans       Float    @default(0)
  transactions   Float    @default(0)

  // ─── Relations ─────────────────────────────────────────────────────────────
  withdrawals         Withdrawal[]
  fundingTransactions FundingTransaction[]
  depositRequests     DepositRequest[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("users")
}

// ─── Withdrawal ─────────────────────────────────────────────────────────────

model Withdrawal {
  id             String   @id @default(cuid())
  transactionId  String   @unique
  amount         Float
  withdrawalType String
  details        Json?
  status         String   @default("PENDING")

  userId         String
  user           User     @relation(fields: [userId], references: [id])

  createdAt      DateTime @default(now())

  @@map("withdrawals")
}

// ─── Deposit Method (admin-managed crypto addresses + network) ───────────────

model DepositMethod {
  id      String  @id @default(cuid())
  method  String  @unique      // e.g. "btc", "eth", "usdt", "ltc"
  details String               // wallet address
  network String  @default("") // e.g. "Bitcoin Network", "ERC20", "TRC20"

  @@map("deposit_methods")
}

// ─── Deposit Request (user-submitted deposit for admin review) ───────────────

model DepositRequest {
  id            String   @id @default(cuid())
  requestId     String   @unique            // e.g. DEP-1234567890-ABCDE
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  amount        Float                        // USD amount user claims to have sent
  cryptoType    String                       // e.g. "bitcoin", "ethereum"
  network       String                       // network used e.g. "ERC20"
  walletAddress String                       // the admin wallet address they sent to
  receiptPath   String?                      // uploaded receipt file path
  status        String   @default("PENDING") // PENDING | APPROVED | REJECTED
  adminNote     String?                      // admin can add a note when reviewing

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("deposit_requests")
}

// ─── Funding Transaction (admin credit operations) ──────────────────────────

model FundingTransaction {
  id            String   @id @default(cuid())
  transactionId String   @unique
  userId        String
  user          User     @relation(fields: [userId], references: [id])
  amount        Float
  currency      String   @default("USD")
  description   String?
  adminNote     String?
  balanceBefore Float
  balanceAfter  Float
  status        String   @default("COMPLETED")
  createdAt     DateTime @default(now())

  @@map("funding_transactions")
}

// ─── Admin ──────────────────────────────────────────────────────────────────

model Admin {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      String   @default("superadmin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}